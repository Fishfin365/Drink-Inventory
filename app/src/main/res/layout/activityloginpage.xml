<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    style="@style/Theme.DrinkInventoryApp"
    android:orientation="vertical"
    android:background="@color/even_darker_grey"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="170dp"
        android:layout_gravity="center"
        android:background="@color/even_darker_grey"
        android:textColor="@color/light_grey2"
        android:textSize="28dp"
        android:id="@+id/signin_prompt"
        android:fontFamily="monospace"
        android:text="Log in to your Account"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="40dp"
        android:textColor="@color/light_grey2"
        android:padding="5dp"
        android:fontFamily="monospace"
        android:text="@string/email_input"/>

    <EditText
        android:id="@+id/email_input"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@color/white"
        android:backgroundTintMode="screen"
        android:textColor="@color/even_darker_grey"
        android:fontFamily="monospace"
        android:padding="5dp"
        android:maxLength="50"
        android:inputType="textEmailAddress"/>

    <TextView
        android:textColor="@color/light_grey2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="20dp"
        android:padding="5dp"
        android:fontFamily="monospace"
        android:text="@string/password"/>

    <EditText
        android:id="@+id/password_input"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@color/white"
        android:backgroundTintMode="screen"
        android:textColor="@color/even_darker_grey"
        android:fontFamily="monospace"
        android:padding="5dp"
        android:maxLength="25"
        android:inputType="textPassword"/>

    <com.google.android.material.button.MaterialButton
        style="@style/App.Button.Primary"
        android:id="@+id/login_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="50dp"
        android:padding="20dp"
        android:text="@string/login_button" />

    <com.google.android.material.button.MaterialButton
        style="@style/App.Button.Primary"
        android:id="@+id/sign_up_button"
        android:layout_marginTop="20dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="Sign up"/>

</LinearLayout>