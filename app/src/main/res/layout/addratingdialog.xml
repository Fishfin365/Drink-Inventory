<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/even_darker_grey"
        android:padding="24dp">

        <!-- Title -->
        <TextView
            android:id="@+id/tvDialogTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add Rating"
            android:textColor="@color/light_grey2"
            android:textSize="20sp"
            android:fontFamily="serif"
            android:layout_marginBottom="20dp" />

        <!-- Item Name -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Name"
            android:textColorHint="@color/light_grey2"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:boxStrokeColor="@color/light_grey2"
            android:layout_marginBottom="14dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/light_grey2"
                android:inputType="textCapWords" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Type Spinner -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ingredient"
            android:textColor="@color/light_grey2"
            android:textSize="10sp"
            android:letterSpacing="0.12"
            android:layout_marginBottom="6dp" />

        <Spinner
            android:id="@+id/spinnerType"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_spinner"
            android:layout_marginBottom="16dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp" />

        <!-- Star Rating -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RATING"
            android:textColor="@color/light_grey2"
            android:textSize="10sp"
            android:letterSpacing="0.12"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <ImageView android:id="@+id/dStar1" android:layout_width="36dp" android:layout_height="36dp"
                android:src="@drawable/ic_star_outline" android:padding="3dp"
                android:clickable="true" android:focusable="true" android:contentDescription="1 star" />
            <ImageView android:id="@+id/dStar2" android:layout_width="36dp" android:layout_height="36dp"
                android:src="@drawable/ic_star_outline" android:padding="3dp"
                android:clickable="true" android:focusable="true" android:contentDescription="2 stars" />
            <ImageView android:id="@+id/dStar3" android:layout_width="36dp" android:layout_height="36dp"
                android:src="@drawable/ic_star_outline" android:padding="3dp"
                android:clickable="true" android:focusable="true" android:contentDescription="3 stars" />
            <ImageView android:id="@+id/dStar4" android:layout_width="36dp" android:layout_height="36dp"
                android:src="@drawable/ic_star_outline" android:padding="3dp"
                android:clickable="true" android:focusable="true" android:contentDescription="4 stars" />
            <ImageView android:id="@+id/dStar5" android:layout_width="36dp" android:layout_height="36dp"
                android:src="@drawable/ic_star_outline" android:padding="3dp"
                android:clickable="true" android:focusable="true" android:contentDescription="5 stars" />
        </LinearLayout>

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancel"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cancel"
                android:textColor="@color/muted"
                app:strokeColor="@color/border"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Save"
                app:cornerRadius="15dp"
                android:backgroundTint="@color/orange_200"
                android:textColor="@color/bg_dark" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>