<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.DrinkInventoryApp" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/even_darker_grey</item>
        <item name="colorPrimaryVariant">@color/dark_grey</item>
        <item name="colorOnPrimary">@color/dark_grey</item>

        <item name="android:colorBackground">@color/even_darker_grey</item>
        <item name="colorSurface">#1E1E1E</item>
        <item name="colorOnBackground">#FFFFFF</item>
        <item name="colorOnSurface">#FFFFFF</item>
    </style>

    <style name="App.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/orange_200</item>
        <item name="android:textColor">@color/even_darker_grey</item>
        <item name="cornerRadius">20dp</item>
        <item name="android:textAllCaps">false</item>
